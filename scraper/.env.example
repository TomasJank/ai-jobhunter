# Copy this file to `.env` and fill in your key. `.env` is gitignored.
#   cp .env.example .env
ANTHROPIC_API_KEY=sk-ant-...
# Optional — scoring model (default: claude-haiku-4-5)
# JH_SCORING_MODEL=claude-haiku-4-5
# Optional — max jobs kept per source (default: 8)
# JH_PER_CONFIG_CAP=8

# Telegram reporting (both required to send; omit both to disable).
# 1. Message @BotFather on Telegram -> /newbot -> copy the token.
# 2. Message your new bot anything, then open
#    https://api.telegram.org/bot<TOKEN>/getUpdates and copy "chat":{"id":...}
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional — minimum match score to notify about (default: 6)
# JH_NOTIFY_MIN_SCORE=6

# Optional — lets the dashboard "Run now" button trigger the daily scrape in the cloud
# (GitHub Actions). Skip these if you have the GitHub CLI installed + logged in (`gh
# auth login`) — the server uses that automatically. Otherwise create a fine-grained
# token with "Actions: read and write" on the repo:
# GITHUB_TOKEN=github_pat_...
# GITHUB_REPO=your-username/ai-jobhunter
